rounded-2xl opacity-20 -z-20 transform scale-[0.9]\\\"></div>\\n      </div>\\n\\n      <!-- Pricing Preview Card -->\\n      <div class=\\\"glass p-6 rounded-2xl border-[#7B39FC]/50 bg-[#100820] relative\\\">\\n        <div class=\\\"absolute -top-2.5 left-1/2 -translate-x-1/2 bg-[#7B39FC] px-3 py-1 rounded-full text-[9px] label-pill\\\">Most Popular</div>\\n        <div class=\\\"flex justify-between items-end mb-4\\\">\\n          <div>\\n            <div class=\\\"label-pill text-[10px] opacity-70\\\">Standard</div>\\n            <div class=\\\"serif text-3xl mt-1\\\">\342\202\2711,499</div>\\n          </div>\\n          <div class=\\\"label-pill text-[10px] text-[#7B39FC]\\\">5 Designs</div>\\n        </div>\\n        <div class=\\\"space-y-2 mb-6\\\">\\n          <div class=\\\"flex items-center gap-2 text-xs\\\">\\n            <svg class=\\\"text-[#7B39FC]\\\" width=\\\"12\\\" height=\\\"12\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"3\\\"><polyline points=\\\"20 6 9 17 4 12\\\"></polyline></svg>\\n            Logo Design Included\\n          </div>\\n          <div class=\\\"flex items-center gap-2 text-xs\\\">\\n            <svg class=\\\"text-[#7B39FC]\\\" width=\\\"12\\\" height=\\\"12\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"3\\\"><polyline points=\\\"20 6 9 17 4 12\\\"></polyline></svg>\\n            Delivery in 3 days\\n          </div>\\n        </div>\\n        <button class=\\\"w-full py-2 bg-[#7B39FC] rounded-lg text-xs font-bold\\\">Select Plan</button>\\n      </div>\\n    </div>\\n  </div>\\n\\n  <!-- Footer Details -->\\n  <div class=\\\"absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-center opacity-40\\\">\\n    <div class=\\\"serif text-lg\\\">Sanjib</div>\\n    <div class=\\\"text-[10px] label-pill\\\">\302\251 2026 Kolkata, India</div>\\n  </div>\\n</div>\\n                    </body>\\n                  </html>\n[AIS_METADATA_SECTION_END]"
    items {
      text: "Apply the \"Sophisticated Dark\" design theme to the app.\n[AIS_METADATA_SECTION_START]\nDesign name: Sophisticated Dark\nDesign instructions: Extract ONLY the styling (colors, fonts, spacing, borders, shadows, backgrounds, gradients) and layout patterns (flexbox/grid structure, component arrangement) from the Design HTML below. Do NOT replace or restructure the existing app\'s HTML elements \342\200\224 preserve all existing components, content, and functionality. Only modify CSS/styling and adjust layout containers as needed to match the theme\'s aesthetic.\nDesign HTML:                   <!doctype html>\\n                  <html>\\n                    <head>\\n                      <meta charset=\\\"UTF-8\\\" />\\n                      <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\" />\\n                      <script src=\\\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\\\"></script>\\n                    </head>\\n                    <body>\\n                      <div class=\\\"w-[1024px] h-[768px] overflow-hidden bg-[#0A0613] text-[#F5F3FF] font-[\'Inter\',_sans-serif] relative select-none\\\">\\n  <style>\\n    @import url(\'https://fonts.googleapis.com/css2?family=Cabin:wght@500&display=swap\');\\n    .glass {\\n      background: rgba(30, 22, 54, 0.4);\\n      backdrop-filter: blur(20px);\\n      border: 1px solid rgba(164, 132, 215, 0.3);\\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);\\n    }\\n    .serif {\\n      font-family: \'Georgia\', serif;\\n      line-height: 1.05;\\n      letter-spacing: -0.02em;\\n    }\\n    .accent-text {\\n      font-style: italic;\\n      background: linear-gradient(to right, #C77DFF, #E0AAFF);\\n      -webkit-background-clip: text;\\n      -webkit-text-fill-color: transparent;\\n    }\\n    .aurora {\\n      background: radial-gradient(circle at 0% 50%, rgba(123, 57, 252, 0.4) 0%, transparent 50%);\\n    }\\n    .label-pill {\\n      font-family: \'Cabin\', sans-serif;\\n      text-transform: uppercase;\\n      letter-spacing: 0.1em;\\n      font-size: 11px;\\n    }\\n    .purple-glow {\\n      box-shadow: 0 0 24px rgba(123, 57, 252, 0.35);\\n    }\\n    .card-stack-item {\\n      position: absolute;\\n      transition: transform 0.3s ease;\\n    }\\n  </style>\\n\\n  <!-- Aurora Glow Background Layer -->\\n  <div class=\\\"absolute inset-0 aurora pointer-events-none\\\"></div>\\n\\n  <!-- Top Navigation -->\\n  <nav class=\\\"absolute top-8 left-8 right-8 flex justify-between items-center z-50\\\">\\n    <div class=\\\"serif text-2xl font-semibold tracking-tight\\\">Sanjib</div>\\n    <div class=\\\"w-10 h-10 glass rounded-lg flex items-center justify-center cursor-pointer hover:border-[#7B39FC] transition-colors\\\">\\n      <svg width=\\\"20\\\" height=\\\"20\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"2\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"><line x1=\\\"3\\\" y1=\\\"12\\\" x2=\\\"21\\\" y2=\\\"12\\\"></line><line x1=\\\"3\\\" y1=\\\"6\\\" x2=\\\"21\\\" y2=\\\"6\\\"></line><line x1=\\\"3\\\" y1=\\\"18\\\" x2=\\\"21\\\" y2=\\\"18\\\"></line></svg>\\n    </div>\\n  </nav>\\n\\n  <div class=\\\"flex h-full p-8 pt-24 gap-8\\\">\\n    <!-- Hero Content (Left) -->\\n    <div class=\\\"w-3/5 flex flex-col justify-center gap-6\\\">\\n      <div class=\\\"flex flex-col gap-3\\\">\\n        <div class=\\\"flex items-center gap-2\\\">\\n          <div class=\\\"glass px-3 py-1 rounded-full flex items-center gap-2 border-[rgba(164,132,215,0.5)]\\\">\\n            <div class=\\\"w-1.5 h-1.5 rounded-full bg-[#7B39FC] animate-pulse\\\"></div>\\n            <span class=\\\"label-pill text-[10px]\\\">Open for Freelance Projects</span>\\n          </div>\\n          <span class=\\\"label-pill text-[#7B39FC]\\\">Available</span>\\n        </div>\\n        <span class=\\\"label-pill text-[rgba(200,195,220,0.7)]\\\">HI, I\'M SANJIB</span>\\n      </div>\\n\\n      <h1 class=\\\"serif text-[84px] leading-tight\\\">\\n        Designs that speak<br/>\\n        before <span class=\\\"accent-text\\\">you do.</span>\\n      </h1>\\n\\n      <p class=\\\"text-[rgba(200,195,220,0.7)] text-lg max-w-md leading-relaxed\\\">\\n        A graphic designer and AI UGC video creator from Kolkata, crafting visuals, brand content, and ad creatives that actually convert.\\n      </p>\\n\\n      <div class=\\\"flex gap-4 mt-4\\\">\\n        <button class=\\\"px-8 py-3 bg-[#7B39FC] purple-glow rounded-xl font-semibold hover:bg-[#8B4FFF] transition-all\\\">\\n          View My Work\\n        </button>\\n        <button class=\\\"px-8 py-3 glass rounded-xl font-semibold hover:bg-[rgba(85,80,110,0.6)] transition-all\\\">\\n          Hire Me\\n        </button>\\n      </div>\\n\\n      <div class=\\\"flex gap-4 mt-8\\\">\\n        <div class=\\\"label-pill glass px-4 py-2 rounded-full cursor-pointer hover:text-[#7B39FC]\\\">About Me</div>\\n        <div class=\\\"label-pill glass px-4 py-2 rounded-full cursor-pointer hover:text-[#7B39FC]\\\">My Works</div>\\n        <div class=\\\"label-pill glass px-4 py-2 rounded-full cursor-pointer hover:text-[#7B39FC]\\\">Pricing</div>\\n        <div class=\\\"label-pill glass px-4 py-2 rounded-full cursor-pointer hover:text-[#7B39FC]\\\">Reach Out</div>\\n      </div>\\n    </div>\\n\\n    <!-- Design System Preview (Right) -->\\n    <div class=\\\"w-2/5 flex flex-col gap-6\\\">\\n      <!-- Skills Preview Card -->\\n      <div class=\\\"glass p-6 rounded-2xl flex flex-col gap-4\\\">\\n        <div class=\\\"label-pill text-[rgba(200,195,220,0.5)]\\\">Core Specialities</div>\\n        <div class=\\\"grid grid-cols-2 gap-3\\\">\\n          <div class=\\\"flex items-center gap-2 glass p-2 rounded-lg text-xs\\\">\\n            <div class=\\\"w-6 h-6 rounded bg-[#7B39FC]/20 flex items-center justify-center text-[#7B39FC]\\\">\\n              <svg width=\\\"14\\\" height=\\\"14\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"2\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"><path d=\\\"M12 19l7-7 3 3-7 7-3-3z\\\"></path><path d=\\\"M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z\\\"></path><path d=\\\"M2 2l7.5 1.5\\\"></path><path d=\\\"M7.67 7.67L12 12\\\"></path></svg>\\n            </div>\\n            Graphic Design\\n          </div>\\n          <div class=\\\"flex items-center gap-2 glass p-2 rounded-lg text-xs\\\">\\n            <div class=\\\"w-6 h-6 rounded bg-[#7B39FC]/20 flex items-center justify-center text-[#7B39FC]\\\">\\n              <svg width=\\\"14\\\" height=\\\"14\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"2\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"><path d=\\\"M23 7l-7 5 7 5V7z\\\"></path><rect x=\\\"1\\\" y=\\\"5\\\" width=\\\"15\\\" height=\\\"14\\\" rx=\\\"2\\\" ry=\\\"2\\\"></rect></svg>\\n            </div>\\n            AI UGC Video\\n          </div>\\n        </div>\\n      </div>\\n\\n      <!-- Works Preview (Stacking Concept) -->\\n      <div class=\\\"relative h-[240px]\\\">\\n        <!-- Mock Stacking Cards -->\\n        <div class=\\\"absolute inset-0 glass rounded-2xl p-4 flex flex-col justify-end overflow-hidden\\\">\\n          <div class=\\\"absolute inset-0 bg-gradient-to-t from-black/80 to-transparent\\\"></div>\\n          <div class=\\\"absolute top-3 right-3 bg-[#7B39FC] px-2 py-0.5 rounded-full text-[9px] label-pill\\\">AI UGC AD</div>\\n          <div class=\\\"relative z-10\\\">\\n            <div class=\\\"text-xs text-[#7B39FC] mb-1\\\">01 / 08</div>\\n            <div class=\\\"font-medium\\\">Creator Content Ad Concept</div>\\n          </div>\\n        </div>\\n        <!-- Peeking background cards -->\\n        <div class=\\\"absolute -top-3 left-4 right-4 h-full glass rounded-2xl opacity-40 -z-10 transform scale-[0.95]\\\"></div>\\n        <div class=\\\"absolute -top-6 left-8 right-8 h-full glass rounded-2xl opacity-20 -z-20 transform scale-[0.9]\\\"></div>\\n      </div>\\n\\n      <!-- Pricing Preview Card -->\\n      <div class=\\\"glass p-6 rounded-2xl border-[#7B39FC]/50 bg-[#100820] relative\\\">\\n        <div class=\\\"absolute -top-2.5 left-1/2 -translate-x-1/2 bg-[#7B39FC] px-3 py-1 rounded-full text-[9px] label-pill\\\">Most Popular</div>\\n        <div class=\\\"flex justify-between items-end mb-4\\\">\\n          <div>\\n            <div class=\\\"label-pill text-[10px] opacity-70\\\">Standard</div>\\n            <div class=\\\"serif text-3xl mt-1\\\">\342\202\2711,499</div>\\n          </div>\\n          <div class=\\\"label-pill text-[10px] text-[#7B39FC]\\\">5 Designs</div>\\n        </div>\\n        <div class=\\\"space-y-2 mb-6\\\">\\n          <div class=\\\"flex items-center gap-2 text-xs\\\">\\n            <svg class=\\\"text-[#7B39FC]\\\" width=\\\"12\\\" height=\\\"12\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"3\\\"><polyline points=\\\"20 6 9 17 4 12\\\"></polyline></svg>\\n            Logo Design Included\\n          </div>\\n          <div class=\\\"flex items-center gap-2 text-xs\\\">\\n            <svg class=\\\"text-[#7B39FC]\\\" width=\\\"12\\\" height=\\\"12\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"3\\\"><polyline points=\\\"20 6 9 17 4 12\\\"></polyline></svg>\\n            Delivery in 3 days\\n          </div>\\n        </div>\\n        <button class=\\\"w-full py-2 bg-[#7B39FC] rounded-lg text-xs font-bold\\\">Select Plan</button>\\n      </div>\\n    </div>\\n  </div>\\n\\n  <!-- Footer Details -->\\n  <div class=\\\"absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-center opacity-40\\\">\\n    <div class=\\\"serif text-lg\\\">Sanjib</div>\\n    <div class=\\\"text-[10px] label-pill\\\">\302\251 2026 Kolkata, India</div>\\n  </div>\\n</div>\\n                    </body>\\n                  </html>\n