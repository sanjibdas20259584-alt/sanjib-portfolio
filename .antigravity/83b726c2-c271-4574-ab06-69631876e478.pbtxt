    replacement_chunks {
      replacement_content: "import { MessageCircle, Palette, Video, Sparkles, Zap, Share2, Heart } from \"lucide-react\";\nimport { motion } from \"motion/react\";\n\nexport const AboutSection = () => {\n  const skills = [\n    { name: \"Graphic Design\", icon: Palette },\n    { name: \"AI UGC Video\", icon: Video },\n    { name: \"Brand Identity\", icon: Sparkles },\n    { name: \"Ad Creatives\", icon: Zap },\n    { name: \"Social Media\", icon: Share2 },\n    { name: \"Story Design\", icon: Heart },\n  ];\n\n  return (\n    <section id=\"about-me\" className=\"w-full max-w-7xl mx-auto px-6 md:px-8 py-20 md:py-32 flex flex-col items-center\">\n      <motion.div \n        initial={{ opacity: 0, y: 30 }}\n        whileInView={{ opacity: 1, y: 0 }}\n        viewport={{ once: true, margin: \"-100px\" }}\n        transition={{ duration: 0.6 }}\n        className=\"flex flex-col items-center text-center space-y-6 max-w-3xl\"\n      >\n        <div className=\"glass-pill\">ABOUT ME</div>\n        \n        <h2 className=\"font-serif text-[48px] md:text-[56px] leading-[1.05] tracking-tight\">\n          The person behind the pixels\n        </h2>\n        \n        <div className=\"space-y-6 text-muted text-lg md:text-xl font-sans text-left md:text-center mt-6\">\n          <p>\n            I\'m Sanjib, a graphic designer and AI UGC video creator based in Kolkata, India. I specialize in creating visual content that doesn\'t just look good \342\200\224 it works. Whether it\'s a scroll-stopping social post, a complete brand identity, or an AI-powered video ad, I bring ideas to life with precision and purpose.\n          </p>\n          <p>\n            With a deep understanding of how audiences interact with content online, I craft visuals that communicate clearly, convert confidently, and leave a lasting impression. Every pixel has a reason. Every design tells a story.\n          </p>\n        </div>\n\n        <div className=\"flex flex-col w-full sm:flex-row gap-4 justify-center pt-8\">\n          <a href=\"#reach-out\" className=\"btn-primary w-full sm:w-auto\">\n            <MessageCircle size={20} /> Let\'s Talk\n          </a>\n          <a href=\"#my-works\" className=\"btn-secondary w-full sm:w-auto\">\n            See My Work\n          </a>\n        </div>\n      </motion.div>\n\n      <div className=\"w-full grid grid-cols-1 md:grid-cols-2 gap-4 mt-20 max-w-4xl\">\n        {skills.map((skill, i) => (\n          <motion.div \n            key={skill.name}\n            initial={{ opacity: 0, y: 20 }}\n            whileInView={{ opacity: 1, y: 0 }}\n            viewport={{ once: true, margin: \"-50px\" }}\n            transition={{ duration: 0.4, delay: i * 0.1 }}\n            className=\"glass-card rounded-2xl p-4 flex items-center gap-4 hover:border-primary transition-colors\"\n          >\n            <div className=\"w-12 h-12 rounded-lg bg-primary/15 text-primary flex items-center justify-center shrink-0\">\n              <skill.icon size={24} />\n            </div>\n            <span className=\"font-medium text-lg text-foreground\">{skill.name}</span>\n          </motion.div>\n        ))}\n      </div>\n\n      <motion.div \n        initial={{ opacity: 0, y: 30 }}\n        whileInView={{ opacity: 1, y: 0 }}\n        viewport={{ once: true, margin: \"-50px\" }}\n        transition={{ duration: 0.6, delay: 0.4 }}\n        className=\"w-full max-w-4xl mt-12 glass-card rounded-[2rem] p-8 md:p-12 flex flex-col md:flex-row justify-between items-center gap-8 md:gap-4 divide-y md:divide-y-0 md:divide-x divide-[rgba(164,132,215,0.2)]\"\n      >\n        <div className=\"flex flex-col items-center justify-center w-full pb-6 md:pb-0\">\n          <span className=\"font-serif text-5xl md:text-6xl text-gradient block mb-2\">50+</span>\n          <span className=\"font-cabin text-sm uppercase tracking-wider text-muted\">Clients served</span>\n        </div>\n        <div className=\"flex flex-col items-center justify-center w-full py-6 md:py-0\">\n          <span className=\"font-serif text-5xl md:text-6xl text-gradient block mb-2\">200+</span>\n          <span className=\"font-cabin text-sm uppercase tracking-wider text-muted\">Projects done</span>\n        </div>\n        <div className=\"flex flex-col items-center justify-center w-full pt-6 md:pt-0\">\n          <span className=\"font-serif text-5xl md:text-6xl text-gradient block mb-2\">3+</span>\n          <span className=\"font-cabin text-sm uppercase tracking-wider text-muted\">Years active</span>\n        </div>\n      </motion.div>\n    </section>\n  );\n};\n"
    }
