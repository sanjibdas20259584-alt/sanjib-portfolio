        replacement_content: "import { useRef, useState } from \"react\";\nimport { works } from \"../data\";\nimport { motion, useScroll, useTransform, MotionValue } from \"motion/react\";\nimport { Play } from \"lucide-react\";\nimport React from \"react\";\n\ninterface CardProps {\n  work: typeof works[0];\n  index: number;\n  total: number;\n  targetScale: number;\n  progress: MotionValue<number>;\n}\n\nconst Card: React.FC<CardProps> = ({ \n  work, \n  index, \n  total,\n  targetScale,\n  progress \n}) => {\n  const containerRef = useRef<HTMLDivElement>(null);\n  \n  // As progress goes from 0 to 1, if this card\'s index is passed, it shrinks\n  const range = [index * 0.1, 1];\n  const scale = useTransform(progress, range, [1, targetScale]);\n  \n  // We can add some slight blur as it goes back\n  const blurValue = useTransform(progress, range, [0, 4]);\n  const blur = useTransform(blurValue, (v) => `blur(${v}px)`);\n\n  return (\n    <div \n      ref={containerRef}\n      className=\"h-[100vh] flex items-center justify-center sticky top-0\"\n    >"
