    replacement_chunks {
      replacement_content: "import { contactLinks } from \"../data\";\nimport { MessageCircle, Mail, Instagram, Linkedin, Send } from \"lucide-react\";\nimport { motion } from \"motion/react\";\n\nconst IconMap: Record<string, any> = {\n  MessageCircle,\n  Mail,\n  Instagram,\n  Linkedin\n};\n\nexport const ContactSection = () => {\n  return (\n    <section id=\"reach-out\" className=\"w-full max-w-7xl mx-auto px-6 md:px-8 py-20 md:py-32\">\n      <motion.div \n        initial={{ opacity: 0, y: 30 }}\n        whileInView={{ opacity: 1, y: 0 }}\n        viewport={{ once: true, margin: \"-100px\" }}\n        transition={{ duration: 0.6 }}\n        className=\"flex flex-col items-center text-center space-y-6 max-w-3xl mx-auto mb-16\"\n      >\n        <div className=\"glass-pill\">GET IN TOUCH</div>\n        \n        <h2 className=\"font-serif text-[44px] md:text-[56px] leading-[1.05] tracking-tight\">\n          Let\'s work <span className=\"italic text-gradient\">together</span>\n        </h2>\n        \n        <p className=\"text-muted text-lg md:text-xl font-sans\">\n          Got a project in mind? Reach out and let\'s create something that stands out.\n        </p>\n      </motion.div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-5xl mx-auto\">\n        <motion.div \n          initial={{ opacity: 0, x: -30 }}\n          whileInView={{ opacity: 1, x: 0 }}\n          viewport={{ once: true, margin: \"-100px\" }}\n          transition={{ duration: 0.6 }}\n          className=\"flex flex-col gap-6\"\n        >\n          <div className=\"font-cabin text-sm uppercase tracking-wider text-muted font-bold mb-2\">\n            REACH ME DIRECTLY\n          </div>\n          \n          <div className=\"flex flex-col gap-4\">\n            {contactLinks.map((link) => {\n              const Icon = IconMap[link.icon];\n              return (\n                <a \n                  key={link.name} \n                  href={link.url}\n                  className=\"glass-card rounded-2xl p-4 flex items-center gap-4 hover:border-primary hover:bg-[rgba(164,132,215,0.1)] transition-all group\"\n                >\n                  <div className={`w-12 h-12 rounded-xl flex items-center justify-center shrink-0 transition-colors ${\n                    link.name === \'LinkedIn\' ? \'bg-pink-500/15 text-pink-400 group-hover:bg-pink-500/30\' : \'bg-primary/15 text-primary group-hover:bg-primary/30\'\n                  }`}>\n                    <Icon size={24} />\n                  </div>\n                  <span className=\"font-medium text-lg text-foreground group-hover:text-white transition-colors\">{link.name}</span>\n                </a>\n              );\n            })}\n          </div>\n        </motion.div>\n\n        <motion.div \n          initial={{ opacity: 0, x: 30 }}\n          whileInView={{ opacity: 1, x: 0 }}\n          viewport={{ once: true, margin: \"-100px\" }}\n          transition={{ duration: 0.6, delay: 0.2 }}\n          className=\"glass-card rounded-[2rem] p-8 md:p-10 flex flex-col gap-6\"\n        >\n          <form className=\"flex flex-col gap-6\" onSubmit={(e) => e.preventDefault()}>\n            <div className=\"flex flex-col gap-2\">\n              <label htmlFor=\"name\" className=\"font-cabin text-sm uppercase tracking-wider text-muted font-bold\">NAME</label>\n              <input \n                type=\"text\" \n                id=\"name\" \n                placeholder=\"Your name\" \n                className=\"w-full glass-card bg-[rgba(30,22,54,0.4)] border border-[rgba(164,132,215,0.2)] rounded-lg px-4 py-3.5 text-foreground placeholder-muted outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all\"\n              />\n            </div>\n            \n            <div className=\"flex flex-col gap-2\">\n              <label htmlFor=\"email\" className=\"font-cabin text-sm uppercase tracking-wider text-muted font-bold\">EMAIL</label>\n              <input \n                type=\"email\" \n                id=\"email\" \n                placeholder=\"your@email.com\" \n                className=\"w-full glass-card bg-[rgba(30,22,54,0.4)] border border-[rgba(164,132,215,0.2)] rounded-lg px-4 py-3.5 text-foreground placeholder-muted outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all\"\n              />\n            </div>\n            \n            <div className=\"flex flex-col gap-2 mb-2\">\n              <label htmlFor=\"message\" className=\"font-cabin text-sm uppercase tracking-wider text-muted font-bold\">MESSAGE</label>\n              <textarea \n                id=\"message\" \n                placeholder=\"Tell me about your project...\" \n                rows={4}\n                className=\"w-full glass-card bg-[rgba(30,22,54,0.4)] border border-[rgba(164,132,215,0.2)] rounded-lg px-4 py-4 text-foreground placeholder-muted outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all resize-none\"\n              />\n            </div>\n            \n            <button type=\"submit\" className=\"btn-primary w-full py-4 rounded-xl text-lg mt-2\">\n              <Send size={20} className=\"mr-1\" />\n              Send Message\n            </button>\n          </form>\n        </motion.div>\n      </div>\n    </section>\n  );\n};\n"
    }
