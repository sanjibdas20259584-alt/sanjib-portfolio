  file_change {
    absolute_path_uri: "file:///src/components/WorksSection.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useRef, useState } from \"react\";\nimport { works } from \"../data\";\nimport { motion, useScroll, useTransform, MotionValue } from \"motion/react\";\nimport { Play } from \"lucide-react\";\n\nconst Card = ({ \n  work, \n  index, \n  total,\n  targetScale,\n  progress \n}: { \n  work: typeof works[0], \n  index: number, \n  total: number,\n  targetScale: number,\n  progress: MotionValue<number>\n}) => {\n  const containerRef = useRef<HTMLDivElement>(null);\n  \n  // As progress goes from 0 to 1, if this card\'s index is passed, it shrinks\n  const range = [index * 0.1, 1];\n  const scale = useTransform(progress, range, [1, targetScale]);\n  \n  // We can add some slight blur as it goes back\n  const blurValue = useTransform(progress, range, [0, 4]);\n  const blur = useTransform(blurValue, (v) => `blur(${v}px)`);\n\n  return (\n    <div \n      ref={containerRef}\n      className=\"h-[100vh] flex items-center justify-center sticky top-0\"\n    >\n      <motion.div \n        style={{ \n          scale,\n          filter: blur,\n          top: `calc(100px + ${index * 12}px)` // staggered top\n        }}\n        className=\"relative w-full max-w-md h-[70vh] md:h-[600px] glass-card rounded-[2rem] overflow-hidden shadow-2xl flex flex-col will-change-transform transform-origin-top\"\n      >\n        {/* Category Pill */}\n        <div className=\"absolute top-4 right-4 z-20 flex gap-2\">\n          {work.type === \'video\' && (\n            <div className=\"bg-primary hover:bg-primary-hover transition-colors rounded-full w-8 h-8 flex items-center justify-center text-white shadow-[0_0_15px_rgba(123,57,252,0.5)]\">\n              <Play size={14} className=\"ml-0.5\" />\n            </div>\n          )}\n          <div className=\"bg-primary/90 backdrop-blur-md rounded-full px-4 py-1.5 text-xs font-cabin tracking-wider font-bold uppercase text-white shadow-lg\">\n            {work.category}\n          </div>\n        </div>\n\n        {/* Media */}\n        <div className=\"absolute inset-0 w-full h-full bg-secondary\">\n          {work.type === \'video\' ? (\n            <video \n              src={work.url}\n              autoPlay\n              loop\n              muted\n              playsInline\n              className=\"w-full h-full object-cover\"\n            />\n          ) : (\n            <img \n              src={work.url} \n              alt={work.title}\n              className=\"w-full h-full object-cover\"\n            />\n          )}\n          {/* Subtle gradient overlay to make text pop */}\n          <div className=\"absolute inset-0 bg-gradient-to-t from-[#0A0613] via-black/20 to-transparent opacity-80\" />\n        </div>\n\n        {/* Text */}\n        <div className=\"absolute bottom-6 left-6 right-6 z-20\">\n          <div className=\"text-primary font-cabin font-bold text-sm mb-2 opacity-90\">\n            {String(index + 1).padStart(2, \'0\')} / {String(total).padStart(2, \'0\')}\n          </div>\n          <h3 className=\"font-sans font-medium text-2xl text-white leading-tight\">\n            {work.title}\n          </h3>\n        </div>\n      </motion.div>\n    </div>\n  );\n};\n\nexport const WorksSection = () => {\n  const containerRef = useRef<HTMLDivElement>(null);\n  const { scrollYProgress } = useScroll({\n    target: containerRef,\n    offset: [\"start start\", \"end end\"]\n  });\n\n  const categories = [\"ALL\", \"AI UGC AD\", \"YOUTUBE THUMBNAIL\", \"PRODUCT POST\", \"POSTER\"];\n  const [activeFilter, setActiveFilter] = useState(\"ALL\");\n\n  const filteredWorks = activeFilter === \"ALL\" \n    ? works \n    : works.filter(w => w.category === activeFilter);\n\n  return (\n    <section id=\"my-works\" className=\"w-full relative pb-20\">\n      <div className=\"max-w-7xl mx-auto px-6 md:px-8 pt-20 md:pt-32\">\n        <div className=\"flex flex-col items-center text-center space-y-6 mb-16\">\n          <div className=\"glass-pill\">MY WORKS</div>\n          \n          <h2 className=\"font-serif text-[44px] md:text-[56px] leading-[1.05] tracking-tight\">\n            Real work, <span className=\"italic text-gradient\">real results</span>\n          </h2>\n          \n          <p className=\"text-muted text-lg md:text-xl font-sans max-w-2xl\">\n            Graphic designs, brand content, and AI UGC video ads \342\200\224 all crafted to convert.\n          </p>\n\n          {/* Filter Pills */}\n          <div className=\"flex w-full overflow-x-auto pb-4 pt-4 hide-scrollbar justify-start md:justify-center gap-3\">\n            {categories.map((cat) => (\n              <button\n                key={cat}\n                onClick={() => setActiveFilter(cat)}\n                className={`shrink-0 rounded-full px-5 py-2.5 text-xs font-cabin tracking-widest font-bold uppercase transition-all ${\n                  activeFilter === cat \n                    ? \'bg-primary text-white shadow-[0_0_15px_rgba(123,57,252,0.4)] border border-primary\' \n                    : \'glass-card text-muted hover:text-white\'\n                }`}\n              >\n                {cat}\n              </button>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      {/* Cards Stack Container */}\n      <div \n        ref={containerRef}\n        className=\"w-full relative px-6 md:px-8\"\n      >\n        {filteredWorks.map((work, i) => {\n          const targetScale = 1 - ( (filteredWorks.length - i) * 0.04 );\n          return (\n            <Card \n              key={work.id} \n              index={i} \n              work={work} \n              total={filteredWorks.length}\n              targetScale={targetScale}\n              progress={scrollYProgress} \n            />\n          );\n        })}\n      </div>\n    </section>\n  );\n};\n"
    }
