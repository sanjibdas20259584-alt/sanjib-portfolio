      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Cabin:wght@500;600&family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-serif: \"Instrument Serif\", serif;\n  --font-sans: \"Inter\", sans-serif;\n  --font-cabin: \"Cabin\", sans-serif;\n\n  --color-background: #0A0613;\n  --color-secondary: #100820;\n  --color-primary: #7B39FC;\n  --color-primary-hover: #8B4FFF;\n  --color-foreground: #F5F3FF;\n  --color-muted: rgba(200, 195, 220, 0.7);\n\n  --color-glass-bg: rgba(30, 22, 54, 0.4);\n  --color-glass-border-subtle: rgba(164, 132, 215, 0.2);\n  --color-glass-border-accent: rgba(164, 132, 215, 0.5);\n  --color-purple-glow: rgba(123, 57, 252, 0.4);\n}\n\n@layer utilities {\n  .glass-card {\n    @apply bg-[var(--color-glass-bg)] backdrop-blur-xl border border-[var(--color-glass-border-subtle)] shadow-[inset_0_1px_0_rgba(255,255,255,0.06)];\n  }\n  .glass-pill {\n    @apply bg-[var(--color-glass-bg)] backdrop-blur-xl border border-[var(--color-glass-border-subtle)] shadow-[inset_0_1px_0_rgba(255,255,255,0.06)] rounded-full text-foreground px-4 py-2 text-sm font-cabin tracking-wider uppercase inline-flex items-center;\n  }\n  .btn-primary {\n    @apply rounded-xl bg-primary hover:bg-primary-hover text-white font-medium py-3 px-6 transition-all shadow-[0_0_24px_rgba(123,57,252,0.35)] flex items-center justify-center gap-2;\n  }\n  .btn-secondary {\n    @apply rounded-xl glass-card py-3 px-6 text-foreground hover:bg-[rgba(164,132,215,0.2)] transition-all font-medium flex items-center justify-center gap-2;\n  }\n  .text-gradient {\n    @apply bg-clip-text text-transparent bg-gradient-to-r from-[#C77DFF] to-[#E0AAFF];\n  }\n}\n\nbody {\n  background-color: var(--color-background);\n  color: var(--color-foreground);\n  font-family: var(--font-sans);\n  -webkit-font-smoothing: antialiased;\n}\n\nhtml {\n  scroll-behavior: smooth;\n}\n"
